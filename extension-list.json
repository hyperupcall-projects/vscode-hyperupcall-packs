[
	{
		"dirname": "pack-decoration-base",
		"packageJson": {
			"name": "vscode-hyperupcall-pack-base",
			"displayName": "Edwin's Pack: Base",
			"description": "Includes things like EditorConfig, Error Lens, etc.",
			"version": "0.13.0",
			"publisher": "EdwinKofler",
			"icon": "assets/icon.png",
			"license": "MPL-2.0",
			"config": {
				"namePretty": "Base"
			},
			"repository": {
				"type": "git",
				"url": "https://github.com/hyperupcall-projects/vscode-hyperupcall-packs"
			},
			"bugs": {
				"url": "https://github.com/hyperupcall-projects/vscode-hyperupcall-packs/issues"
			},
			"author": {
				"name": "Edwin Kofler",
				"url": "https://edwinkofler.com"
			},
			"engines": {
				"vscode": "^1.58.0"
			},
			"files": [
				"LICENSE",
				"assets/icon.png"
			],
			"categories": [
				"Extension Packs"
			],
			"extensionPack": [
				"editorconfig.editorconfig",
				"usernamehw.errorlens",
				"christian-kohler.path-intellisense",
				"naumovs.color-highlight",
				"streetsidesoftware.code-spell-checker",
				"eamodio.gitlens",
				"donjayamanne.githistory",
				"waderyan.gitblame",
				"gruntfuggly.todo-tree",
				"alefragnani.bookmarks",
				"ms-azuretools.vscode-docker",
				"github.copilot-chat",
				"github.vscode-pull-request-github",
				"fill-labs.dependi",
				"ritwickdey.liveserver",
				"jeff-hykin.polacode-2019",
				"ms-vscode-remote.remote-ssh",
				"ms-vscode-remote.remote-ssh-edit",
				"ms-vscode.remote-explorer",
				"ms-vscode-remote.remote-containers",
				"ms-vsliveshare.vsliveshare",
				"bierner.color-info",
				"aaron-bond.better-comments",
				"edwinkofler.vscode-hyperupcall",
				"redhat.vscode-yaml",
				"redhat.vscode-xml",
				"tamasfe.even-better-toml",
				"edwinkofler.vscode-assorted-languages",
				"edwinkofler.vscode-hyperupcall-pack-markdown"
			]
		}
	},
